# RX Homepage — Server Configuration
# Copy to .env and fill in real values

# HTTP server port
PORT=3000

# Admin login credentials
# Email is the username; password is hashed with bcrypt at startup
ADMIN_EMAIL=admin@rx.energy
ADMIN_PASSWORD=change-me-to-a-strong-password

# Session secret — must be a long random string
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-48-bytes-of-random-hex

# Set to "production" when deploying
NODE_ENV=development

# Trust proxy (set to 1 if behind nginx/cloudflare so secure cookies work)
TRUST_PROXY=0
